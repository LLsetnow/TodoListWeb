# 部署到 Sealos 后，将此处替换为你的云函数域名
VITE_API_BASE=https://your-appid.sealos.run

# === 服务端环境变量 ===
# JWT 签名密钥（请替换为随机字符串）
JWT_SECRET=your-secret-key
# Resend API Key（从 resend.com/api-keys 获取）
RESEND_API_KEY=re_xxxxxxxxxxxx
# MongoDB 连接地址
MONGO_URL=mongodb://user:password@host:27017
# 数据库名
DB_NAME=todo
# 服务端口
PORT=3000
# 应用地址（用于邮件中的验证链接，部署时改为实际域名）
APP_URL=http://localhost:3000
